---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
    <img id="site-logo" src="/logos/ben-logo-1.svg" alt="Ben's logo — home" />
  </a>
  <nav class="header-nav">
    <a href="/">Case studies</a>
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
      </svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
      </svg>
    </button>
  </nav>
    </div>
</header>

<script>
  const logos = [
    "/logos/ben-logo1.svg",
    "/logos/ben-logo2.svg",
    "/logos/ben-logo3.svg",
    "/logos/ben-logo4.svg",
  ];
  const random = logos[Math.floor(Math.random() * logos.length)];
  document.getElementById("site-logo").src = random;

  const toggle = document.getElementById("theme-toggle");
  toggle.addEventListener("click", () => {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    if (isDark) {
      document.documentElement.removeAttribute("data-theme");
      localStorage.setItem("theme", "light");
    } else {
      document.documentElement.setAttribute("data-theme", "dark");
      localStorage.setItem("theme", "dark");
    }
  });
</script>