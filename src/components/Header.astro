---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img id="site-logo" src="/logos/ben-logo-1.svg" alt="Ben's logo — home" />
    </a>
    <nav class="header-nav">
      <a href="/">Case studies</a>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const logos = [
    "/logos/ben-logo1.svg",
    "/logos/ben-logo2.svg",
    "/logos/ben-logo3.svg",
    "/logos/ben-logo4.svg",
    "/logos/ben-logo5.svg",
    "/logos/ben-logo6.svg",
  ];
  const random = logos[Math.floor(Math.random() * logos.length)];
  document.getElementById("site-logo").src = random;

  const toggle = document.getElementById("theme-toggle");
  toggle.addEventListener("click", () => {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    if (isDark) {
      document.documentElement.removeAttribute("data-theme");
      localStorage.setItem("theme", "light");
    } else {
      document.documentElement.setAttribute("data-theme", "dark");
      localStorage.setItem("theme", "dark");
    }
  });

  // Measure the header's actual rendered height and expose it as a
  // CSS variable, so other elements (e.g. main's padding-top) can
  // reference the real value instead of a hardcoded guess. Re-runs
  // on resize since header height changes at the mobile breakpoint.
  const header = document.querySelector(".site-header");

  function setHeaderHeight() {
    document.documentElement.style.setProperty(
      "--header-height",
      `${header.offsetHeight}px`
    );
  }

  setHeaderHeight();
  window.addEventListener("resize", setHeaderHeight);

  // Hide header on scroll down, reveal on scroll up.
  // Throttled with requestAnimationFrame so it only updates once per
  // frame rather than on every raw scroll event.
  let lastScroll = 0;
  let ticking = false;

  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const currentScroll = Math.max(window.scrollY, 0);

        if (currentScroll > lastScroll && currentScroll > 100) {
          header.classList.add("header-hidden");
        } else {
          header.classList.remove("header-hidden");
        }

        lastScroll = currentScroll;
        ticking = false;
      });
      ticking = true;
    }
  });
</script>