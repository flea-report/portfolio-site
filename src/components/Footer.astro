---
const phrases = [
  "Made using the technique of positive visualisation · 2026",
  "Made on the precipice of an enormous crossroads · 2026",
  "Made observing the sacred and the propane · 2026",
  "Made using bread from the bread museum · 2026",
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <span id="footer-phrase"></span>
    <a href="https://nz.linkedin.com/in/ben-la-599686b4" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
  </div>
</footer>

<script define:vars={{ phrases }}>
  const pick = phrases[Math.floor(Math.random() * phrases.length)];
  document.getElementById('footer-phrase').textContent = pick;
</script>