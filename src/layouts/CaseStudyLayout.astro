---
import { Image } from 'astro:assets';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectNav from '../components/ProjectNav.astro';
import BaseHead from '../components/BaseHead.astro';

const { data, prev, next } = Astro.props;
---

<html lang="en">
  <head>
  <BaseHead title={`${data.title} — Portfolio`} description={data.overview} image={data.heroImage} />
  </head>
  <body>
    <Header />
    <main>

      <!-- Intro section: light background -->
      <section class="section bg-light intro">
        <div class="section-inner">
          <h1>{data.title}</h1>
          <h2>{data.subheading}</h2>

          <div class="role-block">
            <h3>My role</h3>
            <p>{data.role}</p>
          </div>

          <div class="overview-block">
            <h3>Project overview</h3>
            <p>{data.overview}</p>
          </div>

          <Image class="hero-image" src={data.heroImage} alt={data.heroImageAlt} />
        </div>
      </section>

      <!-- Project details: dark background, rendered from markdown body -->
      <section class="section bg-dark project-details">
        <div class="section-inner prose">
          <slot />
        </div>
      </section>

      <!-- Highlights: each group is its own alternating section -->
      {data.highlights.map((group, index) => (
        <section class={`section highlight-group ${index % 2 === 0 ? 'bg-light' : 'bg-dark'}`}>
          <div class="section-inner">
            <h3>{group.subheading}</h3>
            <p>{group.description}</p>
            <div class={`highlight-images ${group.images.length > 1 ? 'grid-multi' : ''}`}>
              {group.images.map((img) => (
                <figure>
                  <Image src={img.image} alt={img.alt} />
                  <figcaption>{img.caption}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </section>
      ))}

    </main>

    <ProjectNav prev={prev} next={next} />
    <Footer />

  </body>
</html>